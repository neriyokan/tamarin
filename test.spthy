//Host codeのIntegrity（host codeのhashが改竄されていない）


// replay attack 1 
//KMSがQuoteをVerifiedできたら，KMSが発行したnonceと一致しており，そのnonceは1度しか使われない

lemma L_no_replay_attack_on_verifier_fresh:
    "All sid nonce pcr #i.
      KMSVerifiedQuote(sid, pcr, nonce) @ #i
      ==>
      Ex #j.
        KMSIssuedNonce(sid, nonce) @ #j
        & #j < #i
    "
    
lemma L_no_replay_attack_on_verifier_unique:
    "All sid nonce pcr #i1 #i2.
            KMSVerifiedQuote(sid, pcr, nonce) @ #i1
            & KMSVerifiedQuote(sid, pcr, nonce) @ #i2
            ==>
            (#i1 = #i2)"

//EnclaveがQuoteをVerifiedできたら，Enclaveが発行したnonceと一致しており，そのnonceは1度しか使われない
lemma L_no_replay_attack_on_enclave_fresh:
    "All pid_app pid_daemon nonce_uds nonce_uds_recv quote_sig #i.
      Recv_quote_Enclave(pid_app, pid_daemon, nonce_uds, nonce_uds_recv, quote_sig)@ #i
      ==>
      Ex #j.
        EnclaveIssuedNonce(pid_app, pid_daemon, nonce_uds) @ #j
        & #j < #i"
    
lemma L_no_replay_attack_on_enclave_unique:
    "All pid_app pid_daemon nonce_uds nonce_uds_recv quote_sig #i1 #i2.
            Recv_quote_Enclave(pid_app, pid_daemon, nonce_uds, nonce_uds_recv, quote_sig) @ #i1
        &   Recv_quote_Enclave(pid_app, pid_daemon, nonce_uds, nonce_uds_recv, quote_sig) @ #i2
        ==>    
        #i1 = #i2"

//Integrity
////(Daemonから渡されているのは真正，AKで署名されている)
lemma L_integrity: 
    "All pid_app pid_daemon nonce nonce_uds_recv faked_pcr faked_quote_sig quote_sig #i #j.
            Create_Sign_Fakedquote(faked_pcr, nonce, faked_quote_sig) @ #i
            & EnclaveVerifiedQuote(pid_app, pid_daemon, nonce_uds_recv, quote_sig) @ #j
            ==>
            not (faked_quote_sig = quote_sig)
     "



